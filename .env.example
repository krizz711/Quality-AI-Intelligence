# =============================================================================
# Quality AI Agent — environment template (repo ROOT only)
# =============================================================================
# Setup:
#   cp .env.example .env
#   # Edit secrets below, then:
#   docker compose up --build
#
# Do NOT create a second .env under arad-quality-agent/ — that folder is legacy.
# =============================================================================

# --- Runtime ---
ENVIRONMENT=development
LOG_LEVEL=INFO
API_AUTH_KEY=replace-with-a-strong-random-secret-min-32-chars
JWT_SECRET=replace-with-a-strong-jwt-secret-min-32-chars
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3002
ALLOW_MOCK_DATA=false

# --- First-run bootstrap (auto-applied on startup; idempotent) ---
# An initial dashboard login is seeded automatically on first boot so the org
# can sign in immediately. In production ADMIN_PASSWORD is REQUIRED — without it
# no default admin is created (fail-safe).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-admin-password
# Seed a small demo measurement series on a fresh install (handy for first demo).
SEED_DEMO_DATA=false

# --- Autonomous monitoring (continuous SPC analysis + alerting on the stream) ---
ENABLE_AUTONOMOUS_MONITOR=true
MONITOR_INTERVAL_SECONDS=30

# --- MES/QMS auto-connector (scheduled pull of measurements from the org's API) ---
# Set MES_API_URL to enable. The connector polls that endpoint on a timer, pulls
# new records incrementally, maps them, and ingests them — then the monitor
# analyses + alerts. No human action required.
ENABLE_MES_CONNECTOR=true
MES_POLL_INTERVAL_SECONDS=60
MES_API_URL=
MES_API_TOKEN=
# Optional custom auth header (used instead of a Bearer token):
MES_AUTH_HEADER=
MES_AUTH_VALUE=
# Where the records array lives in the JSON response ("" = top-level array, else e.g. "data").
MES_RECORDS_PATH=
# Map our fields -> the API's field names, e.g.:
# {"timestamp":"measuredAt","part_number":"partNo","characteristic_name":"feature","measured_value":"value","nominal_value":"nominal","unit":"unit","operator_id":"operator","equipment_id":"machine","shift":"shift"}
MES_FIELD_MAP=
# Record field used as the dedup id (optional); query param for incremental pulls (optional).
MES_ID_FIELD=
MES_SINCE_PARAM=

# --- Database ---
# Docker Compose maps TimescaleDB to host port 5433 (avoids local Postgres on 5432).
POSTGRES_DB=arad_quality
POSTGRES_USER=arad
POSTGRES_PASSWORD=replace-with-a-strong-db-password
# For API running on the host (make run-api / pytest):
DATABASE_URL=postgresql+asyncpg://arad:replace-with-a-strong-db-password@localhost:5433/arad_quality

# --- Kafka / MLflow ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# Canonical measurement topic (publishers, scripts, and the live consumer must agree).
MEASUREMENTS_TOPIC=quality.measurements
MEASUREMENTS_DLQ_TOPIC=quality.measurements.dlq
MLFLOW_TRACKING_URI=http://localhost:5000

# --- Redis ---
# Leave unset for docker compose (default redis://redis:6379 inside the stack).
# Uncomment ONLY when running the API on the host (make run-api):
# REDIS_URL=redis://localhost:6379/0

# --- Dashboard ---
# Leave unset for docker compose (dashboard reaches API at http://api:8000).
# Set only when running dashboard with: cd dashboard && npm run dev
# API_URL=http://localhost:8000
NEXT_PUBLIC_ALLOW_MOCK_DATA=false
DASHBOARD_URL=http://localhost:3000

# --- Notifications (optional) ---
SLACK_WEBHOOK_URL=
JIRA_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=QUAL

# --- Email SMTP (optional) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=
ALERT_EMAIL_RECIPIENTS=

# --- SMS (optional) ---
SMS_WEBHOOK_URL=
SMS_AUTH_TOKEN=
SMS_FROM_NUMBER=
SMS_TO_NUMBERS=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# --- Integrations (optional) ---
QMS_API_URL=
ML_TOOL_NAME=mlflow

# --- AI summaries (optional — core GR&R/SPC work without this; deterministic fallback if key/quota missing) ---
# The provider is normally chosen in the dashboard (Connections -> AI summaries) and
# its key stored encrypted there. These vars are an optional bootstrap / override.
LLM_PROVIDER=gemini             # gemini | claude | openai
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
ANTHROPIC_API_KEY=              # Claude — defaults to claude-opus-4-8 (set ANTHROPIC_MODEL to change)
OPENAI_API_KEY=                 # OpenAI — defaults to gpt-4o-mini (set OPENAI_MODEL to change)

# --- Admin UIs (docker compose) ---
PGADMIN_DEFAULT_EMAIL=admin@arad.com
PGADMIN_DEFAULT_PASSWORD=replace-with-a-strong-pgadmin-password
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-a-strong-grafana-password
